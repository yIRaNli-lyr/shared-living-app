# Copy to .env.local for local dev. These are read at BUILD time (Vite inlines them).
# Without both variables: signup/login use localStorage only (same browser only).
# With both variables: email/password auth uses Supabase (same account on phone + computer).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Vercel: Project → Settings → Environment Variables → add both for Production,
# then trigger a new deployment so the build picks them up.
# Supabase: run sql from supabase/migrations/, Auth → disable Email Confirm for dev if you want instant login.
